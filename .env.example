# ─── LLM Provider (Required) ──────────────────────────────────────────────────
# Get a free API key at https://console.groq.com
GROQ_API_KEY=gsk_...

# ─── Model Selection ──────────────────────────────────────────────────────────
MODEL_NAME=llama-3.3-70b-versatile

# ─── LangSmith Observability (Required for tracing) ──────────────────────────
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ecommerce-support-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ─── HuggingFace (Optional) ───────────────────────────────────────────────────
# Optional token for higher download rate limits (get one at huggingface.co)
HF_TOKEN=

# ─── RAG Settings ─────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
TOP_K_RETRIEVAL=10
TOP_K_RERANK=3
CHROMA_PERSIST_DIR=./data/chroma_db

# ─── Guardrail Thresholds ─────────────────────────────────────────────────────
MAX_REFUND_AMOUNT=500.0
TOXICITY_THRESHOLD=0.6
RETURN_WINDOW_DAYS=30

# ─── Persistence Paths ────────────────────────────────────────────────────────
MEMORY_DB_PATH=./data/memory.db
EVAL_DB_PATH=./data/eval_metrics.db
